// RepairPilot data model.
// Conventions (see CLAUDE.md):
//  - Every tenant-scoped row carries `shopId`. Queries filter by it.
//  - Money is stored as integer CENTS (never floats).
//  - User references (technician / service writer) are plain ids for v1 to avoid
//    a thicket of named relations; Membership is the enforced Shop<->User link.

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

